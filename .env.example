# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# API proxy (Vercel deployment of the crisp web app)
EXPO_PUBLIC_API_URL=https://your-vercel-app.vercel.app

# RevenueCat (optional — without these, paywall is skipped in dev)
EXPO_PUBLIC_REVENUECAT_API_KEY_IOS=appl_your_key
EXPO_PUBLIC_REVENUECAT_API_KEY_ANDROID=goog_your_key
